# -------------------------------------------------------
# Copy this file to a new file called .env
# Then fill in your two Slack values and your Notion key.
# -------------------------------------------------------

# 1. Your Slack bot token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-token-here

# 2. The ID of your #marketing-insights channel (looks like C01234ABCDE)
#    Find it: right-click the channel in Slack → View channel details → scroll to the very bottom
SLACK_CHANNEL_ID=C01234ABCDE

# 3. Your Notion integration secret (starts with secret_)
NOTION_API_KEY=secret_your-key-here
