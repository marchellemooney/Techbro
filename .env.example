# Slack credentials
# Bot token — needs scopes: channels:history, channels:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# The channel ID for #marketing-insights (not the name — the ID, e.g. C01234ABCDE)
# Find it: right-click the channel in Slack > View channel details > scroll to bottom
SLACK_CHANNEL_ID=C01234ABCDE

# Notion credentials
# Create an integration at https://www.notion.so/my-integrations, then share your database with it
NOTION_API_KEY=secret_your_key_here

# Your Notion database ID (from the URL: notion.so/workspace/<DATABASE_ID>?v=...)
NOTION_DATABASE_ID=7c56d30fe9be4803bd00a91cd5c40ca0

# --- Optional: customize to match your Notion database property names ---
# The "Title" property name in your database (almost always "Name")
NOTION_PROP_TITLE=Name
# A Date property to record when the brief was posted in Slack
NOTION_PROP_DATE=Date
# A text/rich-text property for the full brief content
NOTION_PROP_CONTENT=Content
